# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=

# ── Deployment mode ───────────────────────────────────────────────────────────
# "saas" (default) or "standalone"
DEPLOYMENT_MODE=

# Required only when DEPLOYMENT_MODE=standalone
# Must match the id of an existing Group row in the database
DEFAULT_GROUP_ID=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=

 # Redis — use 'localhost' for local dev, 'redis' for Docker
  REDIS_HOST=localhost
  REDIS_PORT=6379
  REDIS_URL=redis://localhost:6379

# ── Auth / Session ────────────────────────────────────────────────────────────
# Long random string used to sign cookies and JWTs
COOKIE_SECRET=
# Domain for Set-Cookie header (e.g. .example.com — note the leading dot)
COOKIE_DOMAIN=

# Public API base URL (used in emails, webhooks, etc.)
DOMAIN=



# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
# -- Zeptomail (for email testing) ─────────────────────────────────────────────────────
ZEPTOMAIL_API_URL=
ZEPTOMAIL_API_KEY=
DEFAULT_EMAIL_FROM_NAME=
DEFAULT_EMAIL_FROM=