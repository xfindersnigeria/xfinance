{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
        {
            "include": "pdf/**/*",
            
            "outDir": "dist/src/"
        },
        {
        "include": "email/**/*",
        "outDir": "dist/src/"
      }
    ]

  }
}
