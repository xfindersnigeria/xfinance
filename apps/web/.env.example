# ── Auth / Session ────────────────────────────────────────────────────────────
# Must match COOKIE_SECRET in apps/api
COOKIE_SECRET=

# ── Cookie names ──────────────────────────────────────────────────────────────
# Name of the auth token cookie
NEXT_PUBLIC_COOKIE_NAME=


# ── Environment flag ──────────────────────────────────────────────────────────
# Exposed to the browser — e.g. "development", "staging", "production"
NEXT_PUBLIC_ENV=

# URL of the API server
# Local dev: http://localhost:3000
# Docker: http://api:3000
# Production: http://localhost:3000 (Nginx handles proxy, rewrite disabled)
API_URL=

# Enable Next.js rewrite proxy
# true for local dev and Docker testing
# false for production (Nginx handles /backend/* routing)
ENABLE_REWRITE=true
