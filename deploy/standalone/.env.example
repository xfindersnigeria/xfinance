# ── Deployment ───────────────────────────────────
DEPLOYMENT_MODE=standalone
DEFAULT_GROUP_ID=          # set AFTER running: npm run setup:standalone
APP_DOMAIN=                # https://finance.clientdomain.com
LICENSE_KEY=               # provided by XFinance team

# ── Database ─────────────────────────────────────
DB_NAME=xfinance
DB_USER=postgres
DB_PASSWORD=               # use a strong random password
DATABASE_URL=postgresql://postgres:YOURPASSWORD@postgres:5432/xfinance

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────
JWT_SECRET=                # generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRY=7d

# ── Cloudinary (create a free account at cloudinary.com) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email — Resend (create account at resend.com) ────────
RESEND_API_KEY=            # get from resend.com dashboard
RESEND_FROM_EMAIL=         # e.g. noreply@clientdomain.com

# ── Frontend ─────────────────────────────────────
FRONTEND_URL=              # https://finance.clientdomain.com
ALLOWED_DOMAIN=            # clientdomain.com
NEXT_PUBLIC_WS_URL=        # https://finance.clientdomain.com
ENABLE_REWRITE=false       # Nginx handles routing in production

# ── Node ─────────────────────────────────────────
NODE_ENV=production
